PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/saraspos

# JWT
JWT_SECRET=change_this_super_secret_key
JWT_EXPIRES_IN=7d

# OTP / Email (used for forgot password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password
SMTP_FROM="Saras POS <no-reply@saraspos.com>"

# Base URL (used to build absolute URLs for uploaded files / generated PDFs)
BASE_URL=http://localhost:5000

# Uploads
MAX_IMAGE_SIZE_MB=5
